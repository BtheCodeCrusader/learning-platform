<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- ===================== -->
        <!-- DATABASE CONNECTION -->
        <!-- ===================== -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/learning_platform</property>
        <property name="hibernate.connection.username">learning_user</property>
        <property name="hibernate.connection.password">hibernate123</property>

        <!-- ===================== -->
        <!-- DIALECT -->
        <!-- ===================== -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- ===================== -->
        <!-- SCHEMA STRATEGY -->
        <!-- ===================== -->
        <property name="hibernate.hbm2ddl.auto">create</property>

        <!-- ===================== -->
        <!-- LOGGING -->
        <!-- ===================== -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>
        <property name="hibernate.highlight_sql">true</property>

        <!-- ===================== -->
        <!-- ENTITY MAPPINGS -->
        <!-- ===================== -->
        <mapping class="de.learning.platform.model.Person"/>
        <mapping class="de.learning.platform.model.Student"/>
        <mapping class="de.learning.platform.model.Professor"/>
        <mapping class="de.learning.platform.model.Course"/>
        <mapping class="de.learning.platform.model.Enrollment"/>
        <mapping class="de.learning.platform.model.Module"/>
        <mapping class="de.learning.platform.model.Assignment"/>
        <mapping class="de.learning.platform.model.Submission"/>
        <mapping class="de.learning.platform.model.SubmissionId"/>
        <mapping class="de.learning.platform.model.Certificate"/>
        <mapping class="de.learning.platform.model.Category"/>

    </session-factory>
</hibernate-configuration>